{
  "mcpServers": {
   "vercel": {
      "command": "npx",
      "args": ["mcp-remote", "https://mcp.vercel.com"]
    },
   "nostrify": {
      "type": "stdio",
      "command": "deno",
      "args": [
        "run",
        "-A",
        "jsr:@soapbox/docs-mcp",
        "--name",
        "Nostrify",
        "--site",
        "nostrify.dev"
      ]
    }
  }
}
